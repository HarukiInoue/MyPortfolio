{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firebase-debug.log",
      ".firebase/**",
      ".git/**",
      ".git",
      "**/.*",
      "node_modules/**",
      "docs/**",
      ".agents/**",
      "AGENTS.md",
      "README.md",
      "package.json",
      "package-lock.json"
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
